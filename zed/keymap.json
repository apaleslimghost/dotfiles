// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"context": "(Editor && vim_mode != insert) || EmptyPane",
		"bindings": {
			"space space": "command_palette::Toggle",
			"space '": "terminal_panel::Toggle",
			"space @": "workspace::NewCenterTerminal",
			"space /": "pane::DeploySearch",
			"space ;": "vim::ToggleComments",
			"space b b": "tab_switcher::ToggleAll",
			"space b d": "pane::CloseActiveItem",
			"space b h": [
				"workspace::MoveItemToPaneInDirection",
				{
					"direction": "left"
				}
			],
			"space b j": [
				"workspace::MoveItemToPaneInDirection",
				{
					"direction": "up"
				}
			],
			"space b k": [
				"workspace::MoveItemToPaneInDirection",
				{
					"direction": "down"
				}
			],
			"space b l": [
				"workspace::MoveItemToPaneInDirection",
				{
					"direction": "right"
				}
			],
			"space b n": "pane::ActivateNextItem",
			"space b p": "pane::ActivatePreviousItem",
			"space b M": "pane::CloseOtherItems",
			"space g b": "git::Blame",
			"space g g": "git_panel::ToggleFocus",
			"space m r r": "editor::Rename",
			"space p f": "file_finder::Toggle",
			"space p p": "projects::OpenRecent",
			"space t b": "workspace::ToggleRightDock",
			"space t j": "workspace::ToggleBottomDock",
			"space t t": "workspace::ToggleAllDocks",
			"space t c": "workspace::ToggleCenteredLayout",
			"space w v": "pane::SplitRight",
			"space w s": "pane::SplitDown",
			"space w d": "pane::CloseAllItems",
			"space w D": "pane::JoinAll",
			"space w h": "workspace::ActivatePaneLeft",
			"space w j": "workspace::ActivatePaneUp",
			"space w k": "workspace::ActivatePaneDown",
			"space w l": "workspace::ActivatePaneRight",
		},
	},
	{
		"context": "(VimControl && !menu)",
		"bindings": {
			"space": null,
		},
	}
]
